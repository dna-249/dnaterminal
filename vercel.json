{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "public/login.html"
    },
    {
      "src": "/(.*)",
      "dest": "public/signup.html"
    },
    {
      "src": "/(.*)",
      "dest": "public/home.html"
    }
  ]
}